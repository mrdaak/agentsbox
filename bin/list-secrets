#!/usr/bin/env nu
# Lists the secrets a project's agent shell mounts: its own project-scoped
# secrets (agent-<hash>-<name>) plus every global one (agent-global-<name>).
# Mirrors the run-time discovery in the Makefile — `podman secret ls` has no
# label filter, so we match by name prefix then read details via inspect.

def main [
    --project: string   # Project to list secrets for (default: current directory)
    --global            # List only global secrets (mounted in every project)
] {
    let proj = ($project | default $env.PWD | path expand)

    # SHA-1 of the canonical path, first 8 hex — matches the Makefile's
    # `shasum | cut -c1-8` (sha1sum is the same algorithm) so the project hash
    # lines up with the secret names load-secret created. Empty for --global.
    let hash = if $global { "" } else {
        if ($proj | path type) != "dir" {
            print -e $"list-secrets: no such project dir: ($proj)"
            exit 1
        }
        $proj | ^sha1sum | split row " " | first | str substring 0..7
    }

    let all = (^podman secret ls --format '{{.Name}}' | lines)
    let project_names = if $global { [] } else {
        $all | where {|n| $n | str starts-with $"agent-($hash)-" }
    }
    let global_names = ($all | where {|n| $n | str starts-with "agent-global-" })
    let names = ($project_names | append $global_names)

    if ($names | is-empty) {
        if $global {
            print "No global secrets loaded."
        } else {
            print $"No secrets loaded for ($proj)"
        }
        return
    }

    $names | each {|n|
        let labels = (^podman secret inspect $n --format '{{json .Spec.Labels}}' | from json)
        let scope = ($labels | get -o "agents.scope" | default "?")
        let target = ($labels | get -o "agents.target" | default "?")
        let display = if $scope == "global" {
            $n | str replace --regex '^agent-global-' ''
        } else {
            $n | str replace --regex $"^agent-($hash)-" ''
        }
        {name: $display, scope: $scope, target: $target}
    }
}
