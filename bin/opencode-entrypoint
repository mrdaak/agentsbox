#!/usr/bin/env bash
set -e

# Auto-enter nix devShell if flake.nix or shell.nix exists in workspace
# Falls back to plain opencode if nix shell fails

if [ -f /workspace/flake.nix ]; then
    echo "Detected flake.nix, entering nix develop shell..."
    nix develop . --command opencode "$@" || {
        echo "Warning: nix develop failed, running opencode without shell"
        opencode "$@"
    }
elif [ -f /workspace/shell.nix ]; then
    echo "Detected shell.nix, entering nix-shell..."
    nix-shell --command "opencode $@" || {
        echo "Warning: nix-shell failed, running opencode without shell"
        opencode "$@"
    }
else
    opencode "$@"
fi
