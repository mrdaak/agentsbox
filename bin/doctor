#!/usr/bin/env nu

# Hardcoded (matches the README install ref) — the check must not depend on git
# metadata being present on the host.
const GITHUB_REPO = "mrdaak/agentsbox"

def has-cmd [name: string] {
    (which $name | length) > 0
}

def pass [msg: string] { { status: "pass", msg: $msg, fix: "" } }
def fail-check [msg: string, fix: string] { { status: "fail", msg: $msg, fix: $fix } }
def warn-check [msg: string, fix: string] { { status: "warn", msg: $msg, fix: $fix } }

# Tags carry a 'v' prefix; flake.nix's `version` is bare — both parse here so
# check-version compares apples to apples.
def semver [name: string] {
    let s = (if ($name | str starts-with "v") { $name | str substring 1.. } else { $name })
    let parts = ($s | split row ".")
    if ($parts | length) != 3 { return null }
    let nums = ($parts | each {|p| try { $p | into int } catch { null }})
    if ($nums | length) != 3 { return null }
    if ($nums | any {|n| $n == null }) { return null }
    {major: ($nums | get 0), minor: ($nums | get 1), patch: ($nums | get 2)}
}

def check-nix [] {
    if not (has-cmd "nix") {
        return [(fail-check "Nix not installed" "https://nixos.org/download/")]
    }
    let v = (nix --version | str trim)
    let r = (do { nix --extra-experimental-features 'nix-command flakes' flake --help } | complete)
    if $r.exit_code == 0 {
        [
            (pass $"Nix installed \(($v)\)")
            (pass "Flakes available")
        ]
    } else {
        [
            (pass $"Nix installed \(($v)\)")
            (fail-check "Flakes not enabled" "Add 'experimental-features = nix-command flakes' to ~/.config/nix/nix.conf")
        ]
    }
}

def check-podman [] {
    if not (has-cmd "podman") {
        return [(fail-check "Podman not installed" "https://podman.io/docs/installation")]
    }

    let v = (podman --version | str trim)
    mut results = [(pass $"Podman installed \(($v)\)")]

    let machine_list = (do { podman machine list --format '{{.Name}}' } | complete)
    let has_machine = ($machine_list.exit_code == 0) and (($machine_list.stdout | str trim) != "")

    if $has_machine {
        let running = ((podman machine list --format '{{.Running}}' | str trim) | str contains "true")
        if $running {
            $results = ($results | append (pass "Podman machine running"))

            let mem_result = (do { podman machine inspect } | complete)
            if $mem_result.exit_code == 0 {
                let mem = ($mem_result.stdout | from json | get 0.Resources.Memory)
                if $mem >= 8192 {
                    $results = ($results | append (pass $"Podman memory: ($mem) MB"))
                } else {
                    $results = ($results | append (warn-check
                        $"Podman memory: ($mem) MB \(recommend ≥ 8192\)"
                        "podman machine stop ; podman machine set --memory 8192 ; podman machine start"))
                }
            }
        } else {
            $results = ($results | append (fail-check "Podman machine not running" "podman machine start"))
        }
    } else {
        let info_check = (do { podman info } | complete)
        if $info_check.exit_code == 0 {
            $results = ($results | append (pass "Podman running natively \(no VM\)"))
        } else {
            $results = ($results | append (fail-check "Podman not reachable" "podman machine init && podman machine start"))
        }
    }

    $results
}

def check-image [] {
    # The version is threaded from flake.nix via AGENTSBOX_VERSION (see make.nu's
    # image-tag); fall back to `latest` when run outside the wrapper/dev shell.
    # Skip the image probe when podman isn't installed — check-podman already
    # reported that, and probing here would crash with an unhandled external error.
    let tag = ($env.AGENTSBOX_VERSION? | default "latest")
    if not (has-cmd "podman") {
        return []
    }
    let r = (do { podman image exists $"agentsbox:($tag)" } | complete)
    if $r.exit_code == 0 {
        [(pass $"Image agentsbox:($tag) built")]
    } else {
        [(warn-check $"Image agentsbox:($tag) missing" "agentsbox update")]
    }
}

# `warn`, not `fail`: doctor must stay usable offline and must not block
# `enter`, which gates on doctor's fail count — so network/parse failures
# degrade to a soft warn too.
def check-version [] {
    let installed = ($env.AGENTSBOX_VERSION? | default "" | str trim)
    # "latest"/unset => raw `nu make.nu doctor` or a dev shell without the
    # wrapper; no reliable installed version, so skip rather than warn.
    if $installed == "" or $installed == "latest" {
        return []
    }

    let tags = (try {
        http get $"https://api.github.com/repos/($GITHUB_REPO)/tags"
    } catch {
        null
    })
    # null => network/http failure OR a non-list body (e.g. a GitHub rate-limit
    # record); the `get name` below would throw on the latter, so wrap it too.
    if $tags == null {
        return [(warn-check "couldn't check for updates (GitHub unreachable)" "nix profile upgrade agentsbox")]
    }
    let versions = (try {
        $tags | get name | each {|n| semver $n } | where $it != null
    } catch {
        null
    })
    if $versions == null {
        return [(warn-check "couldn't check for updates (GitHub unreachable)" "nix profile upgrade agentsbox")]
    }
    if ($versions | is-empty) {
        return [(pass $"agentsbox ($installed) installed \(no release tags yet\)")]
    }

    let latest = ($versions | sort-by major minor patch | last)
    let inst = (semver $installed)
    if $inst == null {
        return [(warn-check $"agentsbox ($installed) installed \(unparseable version\)" "nix profile upgrade agentsbox")]
    }

    let cmp = (
        if $inst.major < $latest.major { -1 }
        else if $inst.major > $latest.major { 1 }
        else if $inst.minor < $latest.minor { -1 }
        else if $inst.minor > $latest.minor { 1 }
        else if $inst.patch < $latest.patch { -1 }
        else if $inst.patch > $latest.patch { 1 }
        else { 0 }
    )
    let lv = $"v($latest.major).($latest.minor).($latest.patch)"
    if $cmp == 0 {
        [(pass $"agentsbox up to date \(($lv)\)")]
    } else if $cmp < 0 {
        [(warn-check $"agentsbox ($lv) available \(installed ($installed)\)" "nix profile upgrade agentsbox")]
    } else {
        [(pass $"agentsbox ($installed) installed \(ahead of latest tag ($lv)\)")]
    }
}

def main [] {
    print "Checking environment..."
    print ""

    let results = [
        (check-nix)
        (check-podman)
        (check-image)
        (check-version)
    ] | flatten

    for r in $results {
        if $r.status == "pass" {
            print $"  (ansi green)✓(ansi reset) ($r.msg)"
        } else if $r.status == "fail" {
            print $"  (ansi red)✗(ansi reset) ($r.msg)"
            print $"     → ($r.fix)"
        } else {
            print $"  (ansi yellow)!(ansi reset) ($r.msg)"
            print $"     → ($r.fix)"
        }
    }

    let fails = ($results | where status == "fail" | length)
    let warns = ($results | where status == "warn" | length)

    print ""
    if $fails > 0 {
        print $"Failed: ($fails), Warnings: ($warns)"
        exit 1
    }
    print $"All required checks passed \(($warns) warning\(s\)\)"
}
