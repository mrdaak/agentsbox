#!/usr/bin/env bash
set -e

# Zellij names the session (shown in its UI and the terminal title as
# "Zellij (<name>)"). Without an explicit name, `zellij attach --create`
# generates a random one and ignores session_name from the config file, so we
# pass it here. Derived from the agent name; sanitized to the chars Zellij
# accepts in a session name.
SESSION_NAME="$(printf '%s' "${AGENT_NAME:-$(basename "$PWD")}" | tr -c 'A-Za-z0-9_-' '-')"
NIX_BUILD_FLAGS=(--option build-users-group "")
NIX_FLAGS=(--extra-experimental-features "nix-command flakes" "${NIX_BUILD_FLAGS[@]}")

# Start the A2A listener once, before any nix re-exec. The pidfile guards
# against the double-start that would otherwise happen when this script
# re-execs itself through `nix develop --command "$0"`. node and the local
# agent come from the image's global nix profile, so they are on PATH here
# regardless of whether a project dev shell is loaded.
#
# A project can ship its own A2A server at /workspace/.agentsbox/listen (e.g. a
# wiki with a custom skill surface); if present and executable we run that
# instead of the built-in agent-mediated listener. Otherwise fall back.
if [ "${A2A_ENABLED:-}" = "1" ] && [ ! -f /tmp/a2a-listener.pid ]; then
    if [ -x /workspace/.agentsbox/listen ]; then
        A2A_LISTENER=/workspace/.agentsbox/listen
    else
        A2A_LISTENER=listen-message
    fi
    "$A2A_LISTENER" >/tmp/a2a.log 2>&1 &
    echo $! > /tmp/a2a-listener.pid
fi

# Start Zellij's web client once, before any nix re-exec (same double-start
# guard as the A2A listener: this script re-execs itself through `nix develop`).
#
# Zellij binds the loopback only (127.0.0.1:8083). podman's bridge network
# DNATs the published port to the container's external interface, not its
# loopback, so we relay 0.0.0.0:8082 -> 127.0.0.1:8083 with socat to bridge the
# two without Zellij itself binding a public address. make.nu publishes the
# relay port (8082) to the host on $WEB_PORT. The login token is shown only once
# and cannot be retrieved, so print it here on enter
# (see https://zellij.dev/documentation/web-client.html).
if [ "${WEB_ENABLED:-}" = "1" ] && [ ! -f /tmp/zellij-web.started ]; then
    touch /tmp/zellij-web.started
    zellij web --ip 127.0.0.1 --port 8083 --daemonize >/tmp/zellij-web.log 2>&1 || true
    socat TCP-LISTEN:8082,fork,reuseaddr TCP:127.0.0.1:8083 >/tmp/zellij-web-relay.log 2>&1 &
    echo ""
    echo "Zellij web client: http://127.0.0.1:${WEB_PORT:-8082}"
    echo "Login token (shown once — copy it now):"
    zellij web --create-token || echo "  (failed to create token; see /tmp/zellij-web.log)"
    echo ""
fi

if [ -n "$IN_NIX_SHELL" ]; then
    exec zellij attach --create "$SESSION_NAME"
fi

ask_load() {
    local label="$1"
    read -r -p "Detected $label. Load nix environment? [Y/n]: " answer
    case "$answer" in
        [Nn]*) return 1 ;;
        *)     return 0 ;;
    esac
}

print_load_error() {
    echo ""
    echo "┌─────────────────────────────────────────────────────┐"
    echo "│  ERROR: Nix environment failed to load              │"
    echo "│  Agent shell is NOT active.                         │"
    echo "│  Falling back to plain shell.                       │"
    echo "└─────────────────────────────────────────────────────┘"
    echo ""
}

pick_devshell() {
    local shells
    shells=$(nix "${NIX_FLAGS[@]}" flake show --json 2>/dev/null \
        | jq -r '.devShells | to_entries[0].value | keys[]' 2>/dev/null) || true

    if [ -z "$shells" ]; then
        echo "default"
        return
    fi

    local non_default
    non_default=$(echo "$shells" | grep -v '^default$' || true)

    if [ -z "$non_default" ]; then
        echo "default"
        return
    fi

    # Multiple shells — let user pick
    local all_shells=("default")
    while IFS= read -r s; do
        all_shells+=("$s")
    done <<< "$non_default"

    echo "Available devShells:" >&2
    local i=1
    for s in "${all_shells[@]}"; do
        echo "  $i) $s" >&2
        i=$((i + 1))
    done

    local choice
    read -r -p "Select shell [1]: " choice >&2
    choice=${choice:-1}

    echo "${all_shells[$((choice - 1))]:-default}"
}

if [ -f /workspace/flake.nix ]; then
    if ask_load "flake.nix"; then
        shell=$(pick_devshell)
        if [ "$shell" = "default" ]; then
            # Bare `nix develop` resolves devShells.<system>.default OR the
            # legacy singular devShell.<system>; `.#default` only matches the
            # former, so omit the fragment to support devShell-only flakes.
            nix "${NIX_FLAGS[@]}" develop --command "$0" && exit 0
        else
            nix "${NIX_FLAGS[@]}" develop ".#$shell" --command "$0" && exit 0
        fi
        # Reached only if nix develop failed to load — fall back to a plain shell.
        print_load_error
    fi
elif [ -f /workspace/shell.nix ]; then
    if ask_load "shell.nix"; then
        nix-shell "${NIX_BUILD_FLAGS[@]}" --run "$0" && exit 0
        print_load_error
    fi
fi

exec zellij attach --create "$SESSION_NAME"
