#!/usr/bin/env bash
# agents — dispatcher for run / update / doctor
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
    cat <<EOF
Usage: agents [subcommand] [options]

Subcommands:
  run            Run an agent in the current directory (default)
  update         Pull the latest base image and rebuild
  doctor         Check host environment for required tooling
  help           Show this message

Options for 'run':
  --auth         Bind host port 1455:1455 for OpenCode auth flows
EOF
}

cmd_run() {
    local auth=""
    local args=()
    for arg in "$@"; do
        if [[ "$arg" == "--auth" ]]; then
            auth=1
        else
            args+=("$arg")
        fi
    done
    exec make -f "$SCRIPT_DIR/Makefile" run \
        WORKDIR="$PWD" \
        AUTH="$auth" \
        ARGS="${args[*]:-}"
}

cmd_update() {
    exec make -f "$SCRIPT_DIR/Makefile" update
}

cmd_doctor() {
    exec "$SCRIPT_DIR/bin/doctor" "$@"
}

if [[ $# -eq 0 ]]; then
    cmd_run
fi

case "$1" in
    run)            shift; cmd_run "$@" ;;
    update)         shift; cmd_update ;;
    doctor)         shift; cmd_doctor "$@" ;;
    help|-h|--help) usage ;;
    --*)            cmd_run "$@" ;;
    *)              usage; exit 1 ;;
esac
