#!/usr/bin/env bash
# agentsbox — dispatcher for enter / ls / secrets / install-skills / update / doctor
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# First 8 hex of the SHA-1 of a string. Matches make.nu's `workdir-hash`
# (`sha1sum | cut -c1-8`; falls back to shasum, the same algorithm, so the
# project hash lines up regardless of which tool is on PATH).
sha1_8() {
    if command -v shasum >/dev/null 2>&1; then
        printf '%s' "$1" | shasum | cut -c1-8
    else
        printf '%s' "$1" | sha1sum | cut -c1-8
    fi
}

# Bail out with a clear message if podman isn't on PATH. Without this, `enter`
# reaches `podman build` in make.nu, fails to find the binary, and reports an
# (empty) build log — and the secrets/ls paths hit podman directly too.
require_podman() {
    command -v podman >/dev/null 2>&1 || {
        cat >&2 <<'EOF'
agentsbox: podman is required but was not found on your PATH.

  Install Podman: https://podman.io/docs/installation
  After installing, ensure `podman` is on your PATH and run: agentsbox doctor
EOF
        exit 1
    }
}

# Read a single key from .agentsbox/config.toml. nushell PARSES the TOML (never
# sources it), so a project's config can't run code at `enter` time. File and key
# are passed via env to avoid quoting issues.
config_value() {
    local file="$1" key="$2"
    [[ -f "$file" ]] || return 0
    CFG_FILE="$file" CFG_KEY="$key" nu -c \
        'try { open $env.CFG_FILE | get $env.CFG_KEY | into string } catch { "" }' \
        2>/dev/null || true
}

# Read the [[volumes]] array from a config TOML (project or global), emit one
# `name<TAB>target` line per entry (parses, never sources). Validation and
# namespacing happen in make.nu, where the project hash lives.
config_volumes() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    CFG_FILE="$file" nu -c \
        'try { open $env.CFG_FILE | get volumes? | default [] | each { |v| $"($v.name? | default "")\t($v.target? | default "")" } | to text } catch { "" }' \
        2>/dev/null || true
}

# Read the [[ports]] array from a config TOML, emit one `host<TAB>container<TAB>bind`
# line per entry (parses, never sourced). Validation/defaulting is in make.nu.
# Project-only — no global ports (host ports are scarce, not shareable).
config_ports() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    CFG_FILE="$file" nu -c \
        'try { open $env.CFG_FILE | get ports? | default [] | each { |p| $"($p.host? | default "")\t($p.container? | default "")\t($p.bind? | default "")" } | to text } catch { "" }' \
        2>/dev/null || true
}

# Fixed set of agents that can be baked into the image (installed_agents).
# Single source of truth — is_valid_agent and the error messages both read it.
VALID_AGENTS="claude codex pi opencode"

is_valid_agent() {
    local a IFS=$' \t\n'
    for a in $VALID_AGENTS; do
        [[ "$1" == "$a" ]] && return 0
    done
    return 1
}

# Read installed_agents (global-only) from ~/.config/agentsbox.toml as one agent
# name per line. Absent key or malformed value -> empty (caller maps to the
# "all four" default). Parses, never sources.
config_installed_agents() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    CFG_FILE="$file" nu -c \
        'try { open $env.CFG_FILE | get installed_agents | to text } catch { "" }' \
        2>/dev/null || true
}

# Validate a selection read from stdin (one agent name per line): >=1 entry and
# every name in the fixed set. Used by `enter` (config check), the wizard, and
# `config installed_agents`.
validate_agent_names() {
    local name count=0
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        count=$((count + 1))
        is_valid_agent "$name" \
            || { echo "installed_agents: unknown agent '$name' (valid: $VALID_AGENTS)" >&2; return 1; }
    done
    if [[ "$count" -eq 0 ]]; then
        echo "installed_agents: at least one agent is required (valid: $VALID_AGENTS)" >&2
        return 1
    fi
    return 0
}

usage() {
    cat <<EOF
Usage: agentsbox <subcommand> [options]

Subcommands:
  enter [PATH]   Enter an agent shell in PATH (default: current directory)
  ls             List running agent containers (-a stopped, --pretty boxes, --watch live)
  secrets add    Load a file as a podman secret for a project's agent shell
  secrets ls     List secrets mounted in a project's agent shell
  secrets rm     Remove a secret from a project's agent shell
  install-skills Install agentsbox's bundled skills into ~/.agents/skills
  config         Set a config value in .agentsbox/config.toml (--global for ~/.config)
  update         Pull the latest base image and rebuild
  doctor         Check host environment for required tooling
  help           Show this message

Options for 'config' (agentsbox config <field> <value> [options]):
  --global       Edit ~/.config/agentsbox.toml instead of the current project's
                 .agentsbox/config.toml (applies to every project)
  Supported fields:
    agent            the agent to auto-launch in a session
                     (claude, codex, opencode, pi, or 'none' for a plain shell)
    installed_agents which agents get baked into the image at build time
                     (global-only — requires --global; comma-separated, e.g.
                     'claude,codex'; at least one; see 'agentsbox enter' for the
                     one-time selection wizard)

Options for 'enter':
  --auth         Bind host port 1455:1455 for OpenCode auth flows
  --web          Serve Zellij's web client; maps container 8082 to host
                 <index>8082 (agent 1 -> 18082, agent 2 -> 28082, ...) and
                 prints a one-time login token on enter
  --web-bind ADDR  Host address the web port binds to (implies --web). One of:
                 loopback (default, host-only), all (0.0.0.0, LAN+tailnet),
                 tailscale (the host's tailnet IP), or an explicit address
  --a2a          Enable agent-to-agent messaging (start the A2A listener and
                 join the shared agentsbox-net network). Incoming messages are
                 answered by this project's agent (see --agent).
  --name NAME    A2A agent alias other agents address (default: dir basename)
  --agent NAME   Auto-launch this agent in the session instead of a plain shell
                 (e.g. claude, codex, opencode). 'none' forces a plain shell.
                 Overrides the 'agent' key in .agentsbox/config.toml and
                 ~/.config/agentsbox.toml.

  Set a default agent for every project in ~/.config/agentsbox.toml:
      agent = "claude"
  so 'agentsbox enter' opens it without running 'claude' by hand. A project
  may override it for itself with .agentsbox/config.toml:
      agent = "codex"
  Use 'agentsbox config agent <name>' to write either file (add --global for
  the per-user default).

  A project may ship .agentsbox/listen (a custom A2A server — you'll be asked
  to serve it over A2A) and .agentsbox/config.toml (AGENT_NAME default;
  CLI flags override).

  A project may also declare persistent named volumes in .agentsbox/config.toml
  via a [[volumes]] array-of-tables (fields: name, target). On enter each is
  created if missing (as agent-<hash>-<name>) and mounted at target with :Z:

      [[volumes]]
      name   = "go-cache"
      target = "/root/go"

  The same [[volumes]] syntax in ~/.config/agentsbox.toml declares GLOBAL
  volumes (namespaced agent-global-<name>), mounted in every project's session —
  handy for persisting a tool's login/config across projects, e.g. a cursor-cli
  login cached at /root/.cursor. On a shared target the project mount wins.

  A project may declare published ports in .agentsbox/config.toml via a
  [[ports]] array-of-tables (fields: host, container, bind). On enter each maps
  to a podman -p <bind>:<host>:<container>, so a service the agent runs is
  reachable on your host (loopback by default):

      [[ports]]
      host      = 8001
      container = 8001
      bind      = "127.0.0.1"

  bind defaults to 127.0.0.1; "0.0.0.0" widens to the LAN. Project-only — no
  global equivalent. Skipped under network = "host" / container: (podman can't
  publish there).

Options for 'secrets add' (agentsbox secrets add <file> [options]):
  --target PATH  In-container mount path (default: /root/<filename>)
  --name NAME    Secret key (default: <filename>); re-loading replaces it
  --project DIR  Project the secret belongs to (default: current directory)
  --global       Mount in every project's agent shell (not just one project)

Options for 'secrets ls':
  --project DIR  Project to list secrets for (default: current directory)
  --global       List only global secrets (mounted in every project)

Options for 'secrets rm' (agentsbox secrets rm <name> [options]):
  --project DIR  Project the secret belongs to (default: current directory)
  --global       Remove a global secret (mounted in every project)
EOF
}

cmd_enter() {
    require_podman
    local auth="" a2a="" agent_name="" workdir="" web="" web_bind=""
    local launch_agent="" launch_agent_set="" network="" network_set=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --auth) auth=1; shift ;;
            --web)  web=1; shift ;;
            --web-bind) web=1; web_bind="$2"; shift 2 ;;
            --agent) launch_agent="$2"; launch_agent_set=1; shift 2 ;;
            --a2a)  a2a=1; shift ;;
            --name) agent_name="$2"; shift 2 ;;
            --network) network="$2"; network_set=1; shift 2 ;;
            -*)     echo "enter: unknown option: $1" >&2; exit 1 ;;
            *)      workdir="$1"; shift ;;
        esac
    done

    # Project dir defaults to the current directory; canonicalize to an absolute
    # path so the project hash lines up across enter / secrets add / secrets ls.
    workdir="${workdir:-$PWD}"
    [[ -d "$workdir" ]] || { echo "enter: no such directory: $workdir" >&2; exit 1; }
    workdir="$(cd "$workdir" && pwd)"

    # Precedence: CLI flag > .agentsbox/config.toml > built-in default. Config sets
    # identity (AGENT_NAME) and the auto-launch agent, never whether to serve A2A
    # — that stays the user's explicit choice.
    local config="$workdir/.agentsbox/config.toml"
    local global_conf="${XDG_CONFIG_HOME:-$HOME/.config}/agentsbox.toml"
    # Declared [[volumes]] (name<TAB>target per line) from project and global
    # config; validated/mounted/namespaced by make.nu.
    local volumes="" global_volumes="" ports=""
    if [[ -f "$config" ]]; then
        [[ -n "$agent_name" ]] || agent_name="$(config_value "$config" AGENT_NAME)"
        volumes="$(config_volumes "$config")"
        ports="$(config_ports "$config")"
        # network: CLI flag wins, else project config, else global config.
        [[ -n "$network_set" ]] || network="$(config_value "$config" network)"
    fi
    global_volumes="$(config_volumes "$global_conf")"
    # CLI flag and project config already fill $network; only fall back to the
    # global config when both were empty (project beats global, per the AGENTS.md
    # precedence rule). Guarding on $network (not $network_set) preserves a
    # project value when the global file is absent — otherwise the empty global
    # read would clobber it.
    [[ -n "$network" ]] || network="$(config_value "$global_conf" network)"

    # Final fallback: alias = project dir basename.
    [[ -n "$agent_name" ]] || agent_name="$(basename "$workdir")"

    # Precedence: --agent > project config `agent` > global agentsbox.toml `agent`.
    # "none"/unset keeps the plain-shell behavior.
    if [[ -z "$launch_agent_set" ]]; then
        if [[ -f "$config" ]]; then
            launch_agent="$(config_value "$config" agent)"
        fi
        [[ -n "$launch_agent" ]] || launch_agent="$(config_value "$global_conf" agent)"
    fi
    if [[ -n "$launch_agent" && "$launch_agent" != "none" ]]; then
        [[ "$launch_agent" =~ ^[A-Za-z0-9_-]+$ ]] \
            || { echo "enter: invalid agent '$launch_agent' (expected a bare command name, e.g. claude, codex, opencode)" >&2; exit 1; }
    fi

    # installed_agents is global-only and baked into the image at build time.
    # Validate it early so a typo'd name fails here instead of mid-build. Empty
    # (key absent) is valid here and means "all four"; it also gates the
    # first-run wizard below.
    local installed=""
    if [[ -f "$global_conf" ]]; then
        installed="$(config_installed_agents "$global_conf")"
        if [[ -n "$installed" ]]; then
            printf '%s\n' "$installed" | validate_agent_names || exit 1
        fi
    fi

    # First-run wizard: if no installed_agents key is set, stdin is a TTY, and
    # no image exists yet, ask once which agents to bake in. Persists the
    # choice to global config so it never re-prompts (and so make.nu's
    # resolve-installed-agents picks it up for the build that follows). A TTY
    # is required — `input list --multi` errors on non-interactive stdin, so
    # CI / `enter < /dev/null` skip this and build the default (all four).
    if [[ -z "$installed" && -t 0 ]]; then
        local img_tag="${AGENTSBOX_VERSION:-latest}"
        if ! podman image exists "agentsbox:$img_tag" >/dev/null 2>&1; then
            local chosen
            chosen="$(nu "$SCRIPT_DIR/make.nu" select-agents)" || {
                echo "agentsbox: no installed_agents set. Add one in ~/.config/agentsbox.toml or re-run interactively, e.g." >&2
                echo "  agentsbox config installed_agents claude,codex --global" >&2
                exit 1
            }
            printf '%s\n' "$chosen" | validate_agent_names || exit 1
            set_toml_list_key "$global_conf" installed_agents "$chosen"$'\n'
            echo "agentsbox: saved installed_agents to $global_conf"
        fi
    fi

    # --a2a needs a headless agent; if none resolved (or it's "none"), pick one
    # from the installed set and persist it, or fail. Never guess silently — an
    # unconfigured agent would fail every request.
    if [[ -n "$a2a" && ( -z "$launch_agent" || "$launch_agent" == "none" ) ]]; then
        # Re-read in case the first-run wizard above just wrote the key; absent
        # means all four (matches packages.nix's default).
        local installed_now=""
        [[ -f "$global_conf" ]] && installed_now="$(config_installed_agents "$global_conf")"
        local a2a_choices="${installed_now:-$VALID_AGENTS}"
        if [[ -t 0 ]]; then
            local chosen
            chosen="$(AGENTSBOX_A2A_CHOICES="$a2a_choices" nu "$SCRIPT_DIR/make.nu" select-a2a-agent)" || {
                echo "enter: --a2a requires a configured agent (none set). Set one with 'agentsbox config agent <name>' or pass --agent <name>." >&2
                exit 1
            }
            is_valid_agent "$chosen" || { echo "enter: invalid agent '$chosen'" >&2; exit 1; }
            set_toml_key "$config" agent "$chosen"
            launch_agent="$chosen"
            echo "agentsbox: saved agent '$chosen' to $config"
        else
            echo "enter: --a2a requires a configured agent (none set). Set one with 'agentsbox config agent <name>' or pass --agent <name>." >&2
            exit 1
        fi
    fi

    # A project can ship its own A2A server at .agentsbox/listen (e.g. a wiki).
    # If the user didn't pass --a2a, offer to serve it — but only interactively,
    # so joining the shared mesh stays a conscious choice (the file is boot code
    # a cloned repo must not be able to auto-run).
    local listen="$workdir/.agentsbox/listen"
    if [[ -z "$a2a" && -f "$listen" && ! -x "$listen" ]]; then
        echo "agentsbox: $listen exists but is not executable; chmod +x to serve it over A2A" >&2
    fi
    if [[ -z "$a2a" && -x "$listen" && -t 0 ]]; then
        local reply=""
        read -r -p "Detected an A2A listener — serve it on agentsbox-net as '$agent_name'? [y/N]: " reply || reply=""
        case "$reply" in [Yy]*) a2a=1 ;; esac
    fi

    if [[ -n "$a2a" ]]; then
        # The shared user-defined network gives containers DNS-based name
        # resolution, so agents reach each other by alias on a fixed port.
        podman network exists agentsbox-net >/dev/null 2>&1 \
            || podman network create agentsbox-net >/dev/null
    fi

    # A2A answers with this project's agent; --agent is guaranteed non-empty
    # and != "none" whenever --a2a is set (resolved above).
    local run_args=(run --workdir "$workdir" --agent-name "$agent_name")
    [[ -n "$auth" ]] && run_args+=(--auth)
    [[ -n "$a2a" ]] && run_args+=(--a2a)
    [[ -n "$launch_agent" && "$launch_agent" != "none" ]] && run_args+=(--agent "$launch_agent")
    # Pass [[volumes]] to make.nu via AGENTSBOX_VOLUMES (project) and
    # AGENTSBOX_GLOBAL_VOLUMES (global) — one `name:target` per line each.
    # Nushell list flags don't accept repeated values, so env vars are the transport.
    local agentsbox_volumes=""
    if [[ -n "$volumes" ]]; then
        while IFS=$'\t' read -r vname vtarget; do
            [[ -n "$vname" && -n "$vtarget" ]] || { echo "enter: malformed volume in $config (expected name + target)" >&2; exit 1; }
            agentsbox_volumes+="${vname}:${vtarget}"$'\n'
        done <<< "$volumes"
    fi
    local agentsbox_global_volumes=""
    if [[ -n "$global_volumes" ]]; then
        while IFS=$'\t' read -r vname vtarget; do
            [[ -n "$vname" && -n "$vtarget" ]] || { echo "enter: malformed volume in $global_conf (expected name + target)" >&2; exit 1; }
            agentsbox_global_volumes+="${vname}:${vtarget}"$'\n'
        done <<< "$global_volumes"
    fi
    # [[ports]] arrive via AGENTSBOX_PORTS (project-only — no global equivalent;
    # host ports are scarce, not shareable like volumes). Same env-var transport
    # as AGENTSBOX_VOLUMES: one `host:container:bind` per line.
    local agentsbox_ports=""
    if [[ -n "$ports" ]]; then
        while IFS=$'\t' read -r phost pcontainer pbind; do
            [[ -n "$phost" && -n "$pcontainer" ]] || { echo "enter: malformed port in $config (expected host + container)" >&2; exit 1; }
            agentsbox_ports+="${phost}:${pcontainer}:${pbind}"$'\n'
        done <<< "$ports"
    fi
    export AGENTSBOX_VOLUMES="$agentsbox_volumes"
    export AGENTSBOX_GLOBAL_VOLUMES="$agentsbox_global_volumes"
    export AGENTSBOX_PORTS="$agentsbox_ports"
    # `network` is a single scalar, so it rides a sibling env var (same transport
    # pattern as AGENTSBOX_VOLUMES) into make.nu, which appends it as --network.
    export AGENTSBOX_NETWORK="$network"

    # --web exposes Zellij's web client (listens on 8082 in-container). Map it to host
    # port <index>8082 (agent 1 -> 18082, agent 2 -> 28082, …) so concurrent agents
    # don't collide; <index> is the lowest 1-based slot free in `agentsbox ls`, so a
    # stopped agent's slot is reused.
    if [[ -n "$web" ]]; then
        local used index web_port
        used="$(podman ps --filter "name=^agent-" --format '{{.Ports}}' 2>/dev/null \
            | grep -oE '[0-9]+->8082/' | grep -oE '^[0-9]+' || true)"
        index=1
        web_port=$((index * 10000 + 8082))
        while printf '%s\n' "$used" | grep -qx "$web_port"; do
            index=$((index + 1))
            web_port=$((index * 10000 + 8082))
        done

        # Host bind address for the published port. Default loopback is host-only;
        # 'all' (0.0.0.0) and 'tailscale' widen it so other devices (e.g. a phone on
        # the tailnet) can reach it — zellij's one-time token still gates access.
        local bind_addr
        case "${web_bind:-loopback}" in
            loopback|"") bind_addr=127.0.0.1 ;;
            all)         bind_addr=0.0.0.0 ;;
            tailscale)
                bind_addr="$(tailscale ip -4 2>/dev/null | head -n1 || true)"
                if [[ -z "$bind_addr" ]]; then
                    echo "enter: --web-bind tailscale: no Tailscale IPv4 (is tailscale up?); using 127.0.0.1" >&2
                    bind_addr=127.0.0.1
                fi
                ;;
            *)           bind_addr="$web_bind" ;;
        esac
        run_args+=(--web --web-port "$web_port" --web-bind "$bind_addr")
    fi

    exec nu "$SCRIPT_DIR/make.nu" "${run_args[@]}"
}

cmd_list() {
    exec "$SCRIPT_DIR/bin/list" "$@"
}

cmd_load_secret() {
    require_podman
    local file="" name="" target="" project="$PWD" project_set="" global=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --target)  target="$2"; shift 2 ;;
            --name)    name="$2"; shift 2 ;;
            --project) project="$2"; project_set=1; shift 2 ;;
            --global)  global=1; shift ;;
            -*)        echo "secrets add: unknown option: $1" >&2; exit 1 ;;
            *)         file="$1"; shift ;;
        esac
    done

    if [[ -z "$file" ]]; then
        echo "usage: agentsbox secrets add <file> [--target PATH] [--name NAME] [--project DIR | --global]" >&2
        exit 1
    fi
    [[ -f "$file" ]] || { echo "secrets add: no such file: $file" >&2; exit 1; }
    if [[ -n "$global" && -n "$project_set" ]]; then
        echo "secrets add: --global and --project are mutually exclusive" >&2
        exit 1
    fi

    local base secret
    base="$(basename "$file")"
    [[ -n "$name" ]]   || name="$base"
    [[ -n "$target" ]] || target="/root/$base"

    if [[ -n "$global" ]]; then
        # Distinct prefix (a project hash is 8 hex chars, never "global") so the
        # run step can mount globals into every project's shell.
        secret="agent-global-$name"
    else
        [[ -d "$project" ]] || { echo "secrets add: no such project dir: $project" >&2; exit 1; }
        # Canonicalize to match the workdir string make.nu hashes (it uses the
        # --workdir value passed by `enter`), so the project hash lines up at run time.
        project="$(cd "$project" && pwd)"
        secret="agent-$(sha1_8 "$project")-$name"
    fi

    # Re-loading replaces an existing secret of the same name (podman secrets
    # are immutable, so remove then recreate).
    podman secret rm "$secret" >/dev/null 2>&1 || true

    local scope_labels=(--label "agents.target=$target")
    if [[ -n "$global" ]]; then
        scope_labels+=(--label agents.scope=global)
    else
        scope_labels+=(--label agents.scope=project --label "agents.projectdir=$project")
    fi
    podman secret create --label agents.managed=true "${scope_labels[@]}" "$secret" "$file" >/dev/null

    echo "Loaded secret '$secret'"
    if [[ -n "$global" ]]; then
        echo "  mounts at: $target (read-only, in ALL agent shells)"
    else
        echo "  project: $project"
        echo "  mounts at: $target (read-only, in that project's agent shell)"
    fi
}

cmd_remove_secret() {
    require_podman
    local name="" project="$PWD" project_set="" global=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --project) project="$2"; project_set=1; shift 2 ;;
            --global)  global=1; shift ;;
            -*)        echo "secrets rm: unknown option: $1" >&2; exit 1 ;;
            *)         name="$1"; shift ;;
        esac
    done

    if [[ -z "$name" ]]; then
        echo "usage: agentsbox secrets rm <name> [--project DIR | --global]" >&2
        exit 1
    fi
    if [[ -n "$global" && -n "$project_set" ]]; then
        echo "secrets rm: --global and --project are mutually exclusive" >&2
        exit 1
    fi

    local secret
    if [[ -n "$global" ]]; then
        secret="agent-global-$name"
    else
        [[ -d "$project" ]] || { echo "secrets rm: no such project dir: $project" >&2; exit 1; }
        # Canonicalize to match the hash used by `secrets add` / `enter`.
        project="$(cd "$project" && pwd)"
        secret="agent-$(sha1_8 "$project")-$name"
    fi

    # podman secret rm fails loudly if the secret doesn't exist, which is the
    # behavior we want (tells the user nothing matched the given name/scope).
    podman secret rm "$secret" >/dev/null || {
        echo "secrets rm: no such secret: $secret" >&2
        exit 1
    }
    echo "Removed secret '$secret'"
}

cmd_list_secrets() {
    exec "$SCRIPT_DIR/bin/list-secrets" "$@"
}

# Group command: `agentsbox secrets <add|ls|rm> [options]`.
cmd_secrets() {
    local sub="${1:-}"
    [[ $# -gt 0 ]] && shift
    case "$sub" in
        add)            cmd_load_secret "$@" ;;
        ls)             cmd_list_secrets "$@" ;;
        rm)             cmd_remove_secret "$@" ;;
        help|-h|--help) echo "Usage: agentsbox secrets <add|ls|rm> [options]  (see 'agentsbox help')" ;;
        "")             echo "usage: agentsbox secrets <add|ls|rm> [options]" >&2; exit 1 ;;
        *)              echo "secrets: unknown subcommand: $sub (expected add|ls|rm)" >&2; exit 1 ;;
    esac
}

cmd_install_skills() {
    # Skills live in <repo>/skills/<name>/SKILL.md; the shared store ~/.agents/skills
    # is mounted into every sandbox. Claude Code discovers a skill via a relative
    # symlink in ~/.claude/skills pointing back into the store — relative so it
    # resolves the same on the host and in the container (sibling dirs under home).
    local src="$SCRIPT_DIR/skills"
    local store="$HOME/.agents/skills"
    local claude_dir="$HOME/.claude/skills"

    [[ -d "$src" ]] || { echo "install-skills: no skills/ dir at $src" >&2; exit 1; }
    mkdir -p "$store" "$claude_dir"

    local found=""
    for skill in "$src"/*/; do
        [[ -f "${skill}SKILL.md" ]] || continue
        local name
        name="$(basename "$skill")"

        # A prior install may have been left read-only (dir 555 / file 444) by an
        # external process; cp -R then can't overwrite it and the re-install silently
        # stalls. Restore owner-write first so the copy always succeeds.
        [[ -d "$store/$name" ]] && chmod -R u+w "$store/$name"
        # Copy overwrites existing files in place; ln -sfn replaces the symlink.
        # No removal needed — a re-install just updates what's there.
        cp -R "${skill%/}" "$store/"
        ln -sfn "../../.agents/skills/$name" "$claude_dir/$name"
        echo "Installed skill '$name'"
        found=1
    done

    [[ -n "$found" ]] || { echo "install-skills: no skills found in $src" >&2; exit 1; }
    echo "Done. Start a fresh sandbox session to pick them up."
}

# Write a single string key into a TOML file (creating it if missing). nushell
# parses (never sources) the TOML and round-trips it with `to toml`, preserving
# other keys. Value is passed via env to avoid quoting issues.
set_toml_key() {
    local file="$1" key="$2" value="$3"
    mkdir -p "$(dirname "$file")"
    CFG_FILE="$file" CFG_KEY="$key" CFG_VAL="$value" nu -c \
        'if ($env.CFG_FILE | path exists) { open $env.CFG_FILE } else { {} }
            | upsert $env.CFG_KEY $env.CFG_VAL
            | to toml
            | save -f $env.CFG_FILE'
}

# Write a list-of-strings key as a TOML array. Values arrive one per line via
# CFG_LIST (newline-joined); nushell reconstitutes the list so `to toml` emits a
# real array, not a stringified list. Parses, never sources.
set_toml_list_key() {
    local file="$1" key="$2" values="$3"
    mkdir -p "$(dirname "$file")"
    CFG_FILE="$file" CFG_KEY="$key" CFG_LIST="$values" nu -c \
        'if ($env.CFG_FILE | path exists) { open $env.CFG_FILE } else { {} }
            | upsert $env.CFG_KEY ($env.CFG_LIST | lines | where $it != "")
            | to toml
            | save -f $env.CFG_FILE'
}

cmd_config() {
    local field="" value="" global=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --global)  global=1; shift ;;
            -*)        echo "config: unknown option: $1" >&2; exit 1 ;;
            *)         if [[ -z "$field" ]]; then field="$1"; shift
                       elif [[ -z "$value" ]]; then value="$1"; shift
                       else echo "config: unexpected argument: $1" >&2; exit 1; fi ;;
        esac
    done

    if [[ -z "$field" || -z "$value" ]]; then
        echo "usage: agentsbox config <field> <value> [--global]" >&2
        echo "  supported fields: agent, network, installed_agents" >&2
        exit 1
    fi

    local file
    case "$field" in
        agent)
            # Same constraint `enter` enforces on the agent it launches: a bare command
            # name, or the literal 'none' to force a plain shell.
            if [[ "$value" != "none" && ! "$value" =~ ^[A-Za-z0-9_-]+$ ]]; then
                echo "config: invalid agent '$value' (expected a bare command name, e.g. claude, codex, opencode, pi, or 'none')" >&2
                exit 1
            fi
            if [[ -n "$global" ]]; then
                file="${XDG_CONFIG_HOME:-$HOME/.config}/agentsbox.toml"
            else
                file="$PWD/.agentsbox/config.toml"
            fi
            set_toml_key "$file" "$field" "$value"
            ;;
        network)
            # A bare podman --network spec (host / container:<name> / a named net).
            # No shell metachars: this is passed straight to podman run --network.
            if [[ ! "$value" =~ ^[A-Za-z0-9_.:/=-]+$ ]]; then
                echo "config: invalid network '$value' (expected a podman --network spec, e.g. host, container:proxy, agentsbox-net)" >&2
                exit 1
            fi
            if [[ -n "$global" ]]; then
                file="${XDG_CONFIG_HOME:-$HOME/.config}/agentsbox.toml"
            else
                file="$PWD/.agentsbox/config.toml"
            fi
            set_toml_key "$file" "$field" "$value"
            ;;
        installed_agents)
            # Global-only: the image is a host-level artifact, so a per-project
            # value is meaningless and rejected outright.
            if [[ -z "$global" ]]; then
                echo "config: installed_agents is global-only — pass --global" >&2
                exit 1
            fi
            file="${XDG_CONFIG_HOME:-$HOME/.config}/agentsbox.toml"
            # Comma-separated value -> one name per line for the list writer.
            local names=""
            local IFS=','
            for part in $value; do
                part="${part## }"; part="${part%% }"
                [[ -n "$part" ]] || continue
                is_valid_agent "$part" \
                    || { echo "config: invalid agent '$part' (valid: $VALID_AGENTS)" >&2; exit 1; }
                names+="${part}"$'\n'
            done
            if [[ -z "$names" ]]; then
                echo "config: installed_agents requires at least one agent (valid: $VALID_AGENTS)" >&2
                exit 1
            fi
            set_toml_list_key "$file" "$field" "$names"
            ;;
        *)
            echo "config: unsupported field '$field' (supported: agent, network, installed_agents)" >&2
            exit 1
            ;;
    esac

    if [[ -n "$global" ]]; then
        echo "Set $field in $file"
    else
        echo "Set $field = \"$value\" in $file"
    fi
}

cmd_update() {
    require_podman
    exec nu "$SCRIPT_DIR/make.nu" update
}

cmd_doctor() {
    exec "$SCRIPT_DIR/bin/doctor" "$@"
}

if [[ $# -eq 0 ]]; then
    usage
    exit 0
fi

case "$1" in
    enter)          shift; cmd_enter "$@" ;;
    run)            shift; cmd_enter "$@" ;; # alias for enter (backwards compat)
    ls)             shift; cmd_list "$@" ;;
    secrets)        shift; cmd_secrets "$@" ;;
    install-skills) shift; cmd_install_skills "$@" ;;
    config)         shift; cmd_config "$@" ;;
    update)         shift; cmd_update ;;
    doctor)         shift; cmd_doctor "$@" ;;
    help|-h|--help) usage ;;
    --*)            cmd_enter "$@" ;;
    *)              usage; exit 1 ;;
esac
